{
  "name": "hybrid-tech-automotive",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0 <25"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "prisma generate && node -e \"if(process.env.DATABASE_URL){const{execSync}=require('child_process');execSync('npx prisma db push --skip-generate',{stdio:'inherit'})}else{console.log('No DATABASE_URL, skipping db push')}\" && next build",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "sync-batteries": "node scripts/sync-batteries-to-source.js",
    "sync-images": "node scripts/sync-images-to-git.js",
    "sync-all": "node scripts/auto-sync-and-deploy.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.47.0",
    "@stripe/stripe-js": "^2.2.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.2.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.0.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.294.0",
    "next": "14.0.4",
    "nodemailer": "^6.9.7",
    "prisma": "^6.19.3",
    "react": "^18",
    "react-datepicker": "^4.25.0",
    "react-dom": "^18",
    "react-hook-form": "^7.48.2",
    "resend": "^6.9.2",
    "stripe": "^14.9.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "jest": "^30.3.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
