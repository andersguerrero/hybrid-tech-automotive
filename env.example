# Email Configuration
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=info@hybridtechauto.com
SMTP_PASS=your_smtp_password_here
SMTP_SECURE=true

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Business Information
BUSINESS_EMAIL=info@hybridtechauto.com
BUSINESS_PHONE=(832) 762-5299
BUSINESS_ADDRESS=24422 Starview Landing Ct, Spring, TX 77373
NEXT_PUBLIC_BUSINESS_PHONE=(832) 762-5299

# Next.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin Configuration (server-side only)
# Generate the hash with: node scripts/hash-password.js "your-password"
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here
JWT_SECRET=your_jwt_secret_min_32_chars

# Vercel Blob (para subir imágenes en producción)
# Crear Blob Store en Vercel Dashboard → Storage → Blob
# Se configura automáticamente al conectar el Blob Store al proyecto
BLOB_READ_WRITE_TOKEN=
